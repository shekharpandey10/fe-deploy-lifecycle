{
  "compilerOptions": {
    "target": "ES2023",
    "module": "EsNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatiModuleSyntex":true,
    "moduleDetection":"force",
    "noEmit":true,
    "noUnusedLocals":true,
    "noUnusedParameters":true,
    "nofallthroughCasesInSwitch":true
  }
}
